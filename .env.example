# Supabase (optional - falls back to in-memory store without these)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# YouTube Data API (optional - YouTube search is disabled without this)
YOUTUBE_DATA_API_KEY=your-youtube-api-key

# Anthropic API (optional - pronunciation feedback falls back to basic diff without this)
ANTHROPIC_API_KEY=your-anthropic-api-key
